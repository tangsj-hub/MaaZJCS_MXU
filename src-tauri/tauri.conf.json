{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MaaZJCS",
  "version": "0.1.0",
  "identifier": "com.misteo.maazjcs",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MaaZJCS",
        "width": 1000,
        "height": 618,
        "minWidth": 850,
        "minHeight": 525,
        "decorations": true,
        "shadow": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}